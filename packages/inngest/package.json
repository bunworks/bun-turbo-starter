{
  "name": "@acme/inngest",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "bunx inngest-cli@latest dev --url http://localhost:3000/api/inngest",
    "format": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "inngest": "4.7.0"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "26.0.0",
    "typescript": "6.0.3"
  }
}
