{
  "name": "@acme/app-server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun with-env bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@acme/api": "workspace:*",
    "@acme/auth": "workspace:*",
    "@acme/config": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/emails": "workspace:*",
    "@acme/storage": "workspace:*",
    "@orpc/server": "^1.14.6",
    "hono": "4.12.27",
    "superjson": "2.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/bun": "1.3.14",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  }
}
