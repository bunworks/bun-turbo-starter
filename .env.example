# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.
#
# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Default matches the local Postgres from `docker-compose.yml`.
# For Neon, use the `*.neon.tech` connection string (the HTTP driver is selected
# automatically). For Supabase/self-hosted, the standard `node-postgres` driver
# is used. Override the driver explicitly with DB_DRIVER if needed.
POSTGRES_URL="postgres://postgres:password@localhost:5432/acme"

# Force a specific driver: "node" (node-postgres/TCP) or "neon-http".
# Leave empty to auto-detect from POSTGRES_URL.
# DB_DRIVER=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# App URL (used in emails and metadata)
APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_NAME="Acme Inc."
NEXT_PUBLIC_APP_SHORT_NAME="Acme"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: point the web client at a standalone API server (apps/app-server).
# Leave empty to use the built-in Next.js route handler at /api/orpc.
# NEXT_PUBLIC_API_URL=http://localhost:7000

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# REQUIRED in production. Generate with: openssl rand -base64 32
# Leave empty here so a weak default is never shipped by accident.
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET=

# Preconfigured Google OAuth provider (optional)
# @see https://www.better-auth.com/docs/authentication/google
AUTH_GOOGLE_ID=''
AUTH_GOOGLE_SECRET=''

# -----------------------------------------------------------------------------
# Email (local sandbox via inbucket from docker-compose)
# -----------------------------------------------------------------------------
EMAIL_SANDBOX_ENABLED=true
EMAIL_SANDBOX_HOST=localhost
# RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Storage (S3 / local MinIO from docker-compose)
# -----------------------------------------------------------------------------
# AWS_S3_ENDPOINT=http://localhost:9002
# AWS_S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=password
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=files.acme.com

# -----------------------------------------------------------------------------
# Trigger.dev (background jobs & workflows)
# @see https://trigger.dev/docs
# -----------------------------------------------------------------------------
# Secret key from https://cloud.trigger.dev → project → API Keys
TRIGGER_SECRET_KEY=
# Project ref from https://cloud.trigger.dev → project → settings
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Inngest (background jobs, workflows, scheduled tasks)
# @see https://www.inngest.com/docs
# -----------------------------------------------------------------------------
# Event key for sending events to Inngest Cloud (leave empty for local dev)
INNGEST_EVENT_KEY=
# Signing key from https://app.inngest.com → project → manage → signing keys
INNGEST_SIGNING_KEY=
# Override the Inngest API base URL (e.g. for self-hosted or Dev Server)
# INNGEST_BASE_URL=http://localhost:8288

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
# LOG_LEVEL=debug
# OTEL_EXPORTER_OTLP_ENDPOINT=
